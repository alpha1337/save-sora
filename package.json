{
  "name": "save-sora",
  "version": "2.0.20",
  "private": true,
  "type": "module",
  "description": "Save Sora v2 build and release tooling.",
  "engines": {
    "node": ">=18.12.0"
  },
  "scripts": {
    "dev:v2": "vite --config v2/vite.config.ts",
    "build:v2": "node v2/scripts/build-v2.mjs",
    "build:dist": "npm run build:v2 && node scripts/build-dist.mjs",
    "typecheck": "tsc -p v2/tsconfig.json --noEmit",
    "lint": "eslint --no-error-on-unmatched-pattern eslint.config.mjs scripts/build-dist.mjs scripts/bump-version.mjs scripts/ship-release.mjs v2/**/*.{ts,tsx,mts,cts,mjs} --max-warnings=0",
    "test:v2": "vitest run --config v2/vitest.config.ts",
    "validate:file-sizes": "node v2/scripts/validate-file-sizes.mjs",
    "check": "npm run validate:file-sizes && npm run typecheck && npm run lint && npm run test:v2",
    "version:patch": "node scripts/bump-version.mjs patch",
    "version:minor": "node scripts/bump-version.mjs minor",
    "version:major": "node scripts/bump-version.mjs major",
    "version:set": "node scripts/bump-version.mjs",
    "release:patch": "npm run version:patch && npm run build:dist",
    "release:minor": "npm run version:minor && npm run build:dist",
    "release:major": "npm run version:major && npm run build:dist",
    "ship": "node scripts/ship-release.mjs patch",
    "ship:minor": "node scripts/ship-release.mjs minor",
    "ship:major": "node scripts/ship-release.mjs major"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.1.8",
    "clsx": "^2.1.1",
    "fflate": "^0.8.2",
    "idb": "^8.0.2",
    "lucide-react": "^0.511.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/chrome": "^0.0.320",
    "@types/node": "^22.14.1",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "@vitejs/plugin-react": "^4.3.4",
    "esbuild": "^0.25.2",
    "eslint": "^9.24.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "fake-indexeddb": "^6.2.5",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.29.1",
    "vite": "^5.4.18",
    "vitest": "^3.1.1"
  }
}
